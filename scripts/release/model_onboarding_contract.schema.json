{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ferrum model onboarding contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_id",
    "source_git_sha",
    "model",
    "facts",
    "runtime_preset",
    "fallback_policy",
    "capabilities",
    "backend_support"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "contract_id": { "type": "string", "minLength": 1 },
    "source_git_sha": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "family", "architecture", "weight_format", "source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "family": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "weight_format": { "type": "string", "minLength": 1 },
        "source": { "enum": ["hf", "gguf", "local", "synthetic"] },
        "design_doc": { "$ref": "#/$defs/artifact" }
      }
    },
    "facts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokenizer_source",
        "chat_template_source",
        "generation_config_source",
        "token_id_source",
        "eos_token_ids",
        "bos_token_id",
        "stop_tokens",
        "template_golden",
        "template_golden_cases"
      ],
      "properties": {
        "tokenizer_source": { "type": "string", "minLength": 1 },
        "chat_template_source": { "type": "string", "minLength": 1 },
        "generation_config_source": { "type": "string", "minLength": 1 },
        "token_id_source": { "enum": ["metadata", "generation_config", "documented_config"] },
        "eos_token_ids": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "bos_token_id": { "type": ["integer", "null"] },
        "stop_tokens": {
          "type": "array",
          "items": { "type": "string" }
        },
        "template_golden": { "$ref": "#/$defs/artifact" },
        "template_golden_cases": {
          "type": "array",
          "items": {
            "enum": [
              "single_turn",
              "multi_turn",
              "system_message",
              "tool_injection",
              "reasoning_history"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "runtime_preset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected", "rejected_candidates"],
      "properties": {
        "selected": { "type": "string", "minLength": 1 },
        "rejected_candidates": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "fallback_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_builtin_template_fallback",
        "allow_backend_fallback",
        "allow_attention_fallback"
      ],
      "properties": {
        "allow_builtin_template_fallback": { "const": false },
        "allow_backend_fallback": { "const": false },
        "allow_attention_fallback": { "const": false }
      }
    },
    "capabilities": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/capability" }
    },
    "backend_support": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/backend_support" }
    },
    "performance_claims": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "status", "pass_line", "git_sha"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "status": { "const": "pass" },
        "pass_line": { "type": "string", "minLength": 1 },
        "git_sha": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
        "created_at": { "type": "string", "minLength": 1 },
        "entrypoint": { "enum": ["run", "serve"] },
        "backend": { "enum": ["cpu", "cuda", "metal"] },
        "impact_domains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supported", "source"],
      "properties": {
        "supported": { "type": "boolean" },
        "source": { "type": "string", "minLength": 1 },
        "artifact": { "$ref": "#/$defs/artifact" }
      }
    },
    "backend_support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "status", "selection", "fallback", "correctness"],
      "properties": {
        "backend": { "enum": ["cpu", "cuda", "metal"] },
        "status": { "enum": ["supported", "unsupported"] },
        "hardware": { "type": "string", "minLength": 1 },
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["runtime_preset", "scheduler", "attention_impl", "kv_layout", "kv_dtype"],
          "properties": {
            "runtime_preset": { "type": "string", "minLength": 1 },
            "scheduler": { "type": "string", "minLength": 1 },
            "attention_impl": { "type": "string", "minLength": 1 },
            "kv_layout": { "type": "string", "minLength": 1 },
            "kv_dtype": { "type": "string", "minLength": 1 },
            "recurrent_state_max_slots": { "type": ["integer", "null"], "minimum": 0 }
          }
        },
        "fallback": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowed", "actual_backend", "reason"],
          "properties": {
            "allowed": { "const": false },
            "actual_backend": { "enum": ["cpu", "cuda", "metal"] },
            "actual_attention_impl": { "type": "string", "minLength": 1 },
            "reason": { "type": ["string", "null"] }
          }
        },
        "native_operators": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "correctness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "run_artifact",
            "serve_artifact",
            "profile_artifact",
            "replay_artifact",
            "preset_snapshot"
          ],
          "properties": {
            "status": { "enum": ["pass", "fail"] },
            "run_artifact": { "$ref": "#/$defs/artifact" },
            "serve_artifact": { "$ref": "#/$defs/artifact" },
            "profile_artifact": { "$ref": "#/$defs/artifact" },
            "replay_artifact": { "$ref": "#/$defs/artifact" },
            "preset_snapshot": { "$ref": "#/$defs/artifact" },
            "tool_call_artifact": { "$ref": "#/$defs/artifact" },
            "structured_output_artifact": { "$ref": "#/$defs/artifact" },
            "native_operator_artifact": { "$ref": "#/$defs/artifact" }
          }
        },
        "performance_claims": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact" }
        }
      }
    }
  }
}
