+fn pick_vllm_moe_block_size_for_density(total_pairs: usize, num_experts: usize) -> usize {
+    if total_pairs == 0 || num_experts == 0 {
+        return 8;
+    }
+    for bs in [8usize, 16, 32, 48, 64] {
+        if (total_pairs as f64) / (num_experts as f64) / (bs as f64) < 0.9 {
+            return bs;
+        }
+    }
+    64
